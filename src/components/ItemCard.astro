---
import FormattedDate from "./FormattedDate.astro";
import { cn } from "@/lib/utils";

type Props = {
  img?: string;
  link?: string;
  title: string;
  date?: Date;
  tags?: string[];
  highlightTag?: string;
  _tag?: string;
};

const { highlightTag, _tag, img, link, title, date, tags } = Astro.props;
---

<div class="relative">
  <a href={link} target="_blank" class="peer">
    <div class="relative overflow-hidden rounded-md border-2 border-black">
      <div
        class="bg-svg1 relative z-10 flex h-full w-full flex-col items-start bg-white p-3"
      >
        {
          _tag && (
            <div
              class="absolute -top-1 -right-1 z-20 rounded-tr-md rounded-bl-lg bg-black px-3 py-1
                text-sm text-white"
            >
              {`_tag: "${_tag}"`}
            </div>
          )
        }
        {
          img && (
            <>
              <div class="relative w-full overflow-hidden rounded-md bg-black pb-[56.25%]">
                <img
                  src={img}
                  alt="An image representing this card"
                  class="absolute top-0 left-0 h-full w-full object-cover"
                />
              </div>
              <div class="py-2" />
            </>
          )
        }
        <h4 class="text-lg font-bold text-wrap">
          <span
            class="relative inline-block before:absolute before:top-0 before:right-0
              before:bottom-0 before:left-0 before:-z-10 before:bg-white before:blur-[0.5em]
              before:content-['']"
            >{title}
          </span>
          {
            date && (
              <>
                <div class="py-1" />
                <p class="text-sm italic">
                  <span
                    class="relative inline-block before:absolute before:top-0 before:right-0
                      before:bottom-0 before:left-0 before:-z-10 before:bg-white before:blur-[0.5em]
                      before:content-['']"
                  >
                    <FormattedDate date={date} />
                  </span>
                </p>
              </>
            )
          }
        </h4>
      </div>
    </div>
  </a>
  <div
    class="transition-top bg-svg2 absolute top-[0.5em] left-[0.5em] -z-10 h-full w-full
      rounded-md duration-300 peer-hover:-top-[0.5em]"
  >
  </div>
  {
    tags && tags.length > 0 && (
      <div class={"absolute right-2 bottom-2 z-10"}>
        {tags?.map((tag) => (
          <a href={`/tags/${tag}`}>
            <p
              class={cn(
                `relative inline-block rounded-xl border border-black px-1 text-sm
                before:absolute before:top-0 before:right-0 before:bottom-0 before:left-0
                before:-z-10 before:bg-white before:blur-[0.5em] before:content-['']
                hover:bg-black hover:text-white hover:filter-none hover:before:bg-transparent
                hover:before:filter-none`,
                {
                  "bg-black text-white filter-none before:bg-transparent before:filter-none":
                    tag === highlightTag,
                },
              )}
              transition:name={`${title}:tag:${tag}`}
            >
              {tag}
            </p>
          </a>
        ))}
      </div>
    )
  }
</div>
